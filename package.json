{
  "name": "@justpinero/create-cascade",
  "version": "0.1.0",
  "description": "One-command installer for Cascade — AI-powered multi-project orchestration.",
  "type": "module",
  "bin": {
    "create-cascade": "./dist/create-cascade.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/create-cascade.js --format=esm --banner:js=\"#!/usr/bin/env node\" && chmod +x dist/create-cascade.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "cascade",
    "scaffold",
    "installer",
    "ai",
    "claude"
  ],
  "author": "Justin Piñero",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JustPinero/create-cascade.git"
  }
}
